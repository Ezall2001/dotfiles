export const CURSOR_SIZE = 36
export const CURSOR_THEME_DIR = "~/.config/themes/cursor" | path expand
export const CURSOR_DIR = '~/.local/share/icons/default_cursor' | path expand -n

export const ASSETS_PATH = '~/.config/hypr/assets' | path expand -n
export const WALLPAPER_PATH = $ASSETS_PATH | path join 'wallpaper'
export const LOCKSCREEN_PATH = $ASSETS_PATH | path join 'lockscreen'
