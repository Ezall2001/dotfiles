#!/usr/bin/env nu

use ../../hyprland/hyp_log [main]

const ERROR_JSON = {
		text: 'waybar_weather:error'
		tooltip: ''
}

def main [] {
	try {
		~/.config/scripts/waybar/waybar_weather/dist/waybar_weather
	} catch {|e|
		hyp_log $e.rendered waybar_weather --notify 'waybar_weather' --level error
		$ERROR_JSON | to json --raw
	}
}
