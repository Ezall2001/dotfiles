#!/usr/bin/env nu

use ../hyprland/hyp_log [main]

def get_data [field] {
	nvidia-smi --query-gpu=($field) --format=csv,nounits,noheader
	| str replace ' ' ''
	| from csv --noheaders
	| get column0
	| first
}

def usage [] {
	let val = try {
		get_data utilization.gpu
	} catch {|e|
		hyp_log $e.rendered 'waybar_gpu usage' --notify 'waybar_gpu error' --level error
		null
	}

	let text = if $val == null {
		'gpu:error'
	} else {
		$"<span size='12000'>󰾲</span> ($val)"
	}

	{
		text: $text
		alt: ""
		tooltip: ""
		class: "gpu-usage"
		percentage: 0
	} | to json -r
}

def temp [] {
	let val = try {
		get_data temperature.gpu
	} catch {|e|
		hyp_log $e.rendered 'waybar_gpu temp' --notify 'waybar_gpu error' --level error
		null
	}

	let text = if $val == null {
		'gpu:error'
	} else {
		$"($val)°C"
	}


	{
		text: $text
		alt: ""
		tooltip: ""
		class: "gpu-temp"
		percentage: 0
	} | to json -r
}

def main [] {}
def 'main usage' [] {usage}
def 'main temp' [] {temp}
