#!/usr/bin/env nu

export def main [tag: string]: nothing -> nothing {
  let workspace_name = match $tag {
    'p_browser' => 'browser'
    'p_terminal' => 'terminal'
    'p_notes' => 'notes'
  }

  let window = hyprctl -j clients | from json | where $tag in $it.tags | first
  let active_ws = hyprctl -j activeworkspace | from json

  if $window.workspace.name == $'special:($workspace_name)' {
    hyprctl dispatch movetoworkspacesilent $'($active_ws.id), pid:($window.pid)'
  } else {
    hyprctl dispatch movetoworkspacesilent $'special:($workspace_name), pid:($window.pid)'
  }

}
