#!/usr/bin/env nu

use /usr/bin/scripts/hyprland/hyp_backlight/mod.nu [_main]
use /usr/bin/scripts/hyprland/hyp_backlight/menu [_menu]
use /usr/bin/scripts/hyprland/hyp_backlight/menu/input.nu [get_input]
use /usr/bin/scripts/hyprland/hyp_backlight/menu/actions.nu [set_brightness]
use /usr/bin/scripts/hyprland/hyp_backlight/controls.nu [increase decrease]

def main [name?:string pct?:int] { _main $name $pct }

def 'main increase' [pct:int --name(-n):string --notify(-t)] {
	increase $pct --name=$name --notify=$notify
}

def 'main decrease' [pct:int --name(-n):string --notify(-t)] {
	decrease $pct --name=$name --notify=$notify
}

def 'main _menu' [] {_menu}
def 'main _input' [] {get_input}
def 'main _action set_brightness' [name:string pct:int] {set_brightness $name $pct}
