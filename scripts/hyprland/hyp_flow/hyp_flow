#!/usr/bin/env nu

use /usr/bin/scripts/hyprland/hyp_flow/focus.nu [main]
use /usr/bin/scripts/hyprland/hyp_flow/pull.nu [main]
use /usr/bin/scripts/hyprland/hyp_flow/push.nu [main]
use /usr/bin/scripts/hyprland/hyp_flow/change_vws_col.nu [main]

use /usr/bin/scripts/hyprland/hyp_flow/secondary_vws [_menu main]
use /usr/bin/scripts/hyprland/hyp_flow/secondary_vws/actions.nu
use /usr/bin/scripts/hyprland/hyp_flow/secondary_vws/input.nu [get_input]

def main [] {}

def 'main focus' [row:int type:string] {focus $row $type}
def 'main pull' [row:int type:string] { pull $row $type }
def 'main push' [addr?:string] { push $addr }
def 'main change_vws_col' [new_col:int row?:int type?:string] {
	change_vws_col $new_col $row $type
}

def 'main secondary_vws' [] {secondary_vws}
def 'main secondary_vws _menu' [] {_menu}
def 'main secondary_vws _input' [] {get_input}
def 'main secondary_vws _action push_pull' [addr:string] {actions push_pull $addr}
def 'main secondary_vws _action make_primary' [addr:string] {actions make_primary $addr}
