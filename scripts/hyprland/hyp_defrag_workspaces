#!/usr/bin/env nu

def move_clients [workspace:int, client_pids:list<int>] {
  $client_pids | each { hyp_workspace move $workspace $in --silent}
}

export def main [monitor?: string] {
  let monitors = hyprctl monitors -j | from json

  let _monitor = if $monitor == null {
    $monitors | where focused == true
  } else {
    $monitors | where name == $monitor
  } | first

  let mon_name = $_monitor | get name
  let mon_id = $_monitor | get id

  let clients = hyprctl clients -j | from json | where monitor == $mon_id

  let focused_pid = try {$clients | where focusHistoryID == 0 | first | get pid} catch {null}

  $clients 
  | select pid workspace.id | rename pid workspace
  | where workspace > 0
  | update workspace {$in | into int}
  | group-by --to-table workspace 
  | sort-by workspace
  | merge (1..10 | wrap new_workspace)
  | each {move_clients $in.new_workspace $in.items.pid}

  if $focused_pid == null {return}

  hyprctl dispatch focuswindow $"pid:($focused_pid)"

}
