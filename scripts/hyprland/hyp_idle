#!/usr/bin/env nu

def set_brightness [dev:string, pct:float] {
	let curr_pct = brightnessctl -m i -d $dev | split row ',' | get 3 | str substring 0..-2 | into float
	let set_pct = [$curr_pct, $pct] | math min | $'($in)%'
	brightnessctl s $set_pct -s -d $dev
}

def wake_up [] {
		brightnessctl -r -d intel_backlight
		brightnessctl -r -d asus::kbd_backlight 
		hyprctl dispatch dpms on eDP-1
		hyprctl dispatch dpms on HDMI-A-1 
}

def get_action [idx?:int] {
	let lvl0 = {|| hyprlock }

	let lvl1 = {||
		set_brightness intel_backlight 5
		set_brightness asus::kbd_backlight 0
		hyprctl dispatch dpms off HDMI-A-1 
	}

	let lvl2 = {||
		hyprctl dispatch dpms off eDP-1
	}

	let actions = [$lvl0 $lvl1 $lvl2]
	let action = try {$actions | get $idx} catch {null}
	$action
}

export def main [level?: int, --wakeup (-w)]: nothing -> nothing {
	if $wakeup {
		wake_up
		return
	}

	let action = get_action $level
	if $action == null {
		print 'action not found'
		return
	}

	do $action
}
