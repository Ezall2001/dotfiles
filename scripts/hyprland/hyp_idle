#!/usr/bin/env nu

def 'level0 action' [] {
    brightnessctl s 5% -s -d intel_backlight
    brightnessctl s 0 -s -d asus::kbd_backlight 
    brightnessctl s 0% -s -d ddcci2
}

def 'level0 rev' [] {
    brightnessctl -r -d intel_backlight
    brightnessctl -r -d asus::kbd_backlight 
    brightnessctl -r -d ddcci2
}


export def main [level: int, --reverse (-r)]: nothing -> nothing {
  match $level {
    0 => {if $reverse {level0 rev} else {level0 action}}
    _ => {print 'unknown level'}
  }

}

