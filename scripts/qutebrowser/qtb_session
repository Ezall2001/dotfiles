#!/usr/bin/env nu

def consts [] {
	let BASE_DIR = "/tmp/qtb" | path expand

	let DOT_CONFIG_DIR = "~/.config/qutebrowser" | path expand

	let SHARED_SESSION_DIR = $BASE_DIR | path join "shared_data"
	let SHARED_CACHE_DIR = $SHARED_SESSION_DIR | path join "cache"
	let SHARED_DATA_DIR = $SHARED_SESSION_DIR | path join "data"
	let SHARED_CONFIG_DIR = $SHARED_SESSION_DIR | path join "config"
	let SHARED_MANAGED_CONFIG_DIR = $SHARED_CONFIG_DIR | path join "managed"

	{
		BASE_DIR: $BASE_DIR,
		DOT_CONFIG_DIR: $DOT_CONFIG_DIR,
		SHARED_SESSION_DIR: $SHARED_SESSION_DIR,
		SHARED_CACHE_DIR: $SHARED_CACHE_DIR,
		SHARED_DATA_DIR: $SHARED_DATA_DIR,
		SHARED_CONFIG_DIR: $SHARED_CONFIG_DIR
		SHARED_MANAGED_CONFIG_DIR: $SHARED_MANAGED_CONFIG_DIR 
	}
}

def get_session_paths [session:string] {
	let c = consts
	let base_dir = $c.BASE_DIR | path join $session

	let dot_session_config_dir = $c.DOT_CONFIG_DIR | path join $session
	let session_config_dir = $base_dir | path join 'config'

	let dot_config_entry = $dot_session_config_dir | path join 'main.py'
	let session_config_entry = $session_config_dir | path join 'managed' $session 'main.py'

	{
		base_dir:$base_dir,
		dot_session_config_dir:$dot_session_config_dir,
		session_config_dir:$session_config_dir,
		dot_config_entry:$dot_config_entry,
		session_config_entry:$session_config_entry,
	}
}

def get_session [session?:string] {
	$session
}

def main [] { }
def 'main start' [session?:string] {start $session}
def 'main create' [session:string, --open (-o)] {create $session --open=$open}
def 'main delete' [session?:string] {delete $session}
def 'main reset_data' [] {reset_data}

export def reset_data [] {
	let c = consts
	rm -rf $c.SHARED_SESSION_DIR 

	mkdir $c.SHARED_SESSION_DIR
	mkdir $c.SHARED_CACHE_DIR
	mkdir $c.SHARED_DATA_DIR
	mkdir $c.SHARED_CONFIG_DIR

	ln -s $c.DOT_CONFIG_DIR $c.SHARED_MANAGED_CONFIG_DIR
}

export def create [session:string, --open (-o)] {
	let c = consts
	let s = get_session_paths $session

	if ($s.base_dir | path exists) {
		print 'session exists'
		return
	}

	mkdir $s.base_dir
	ln -s $c.SHARED_CACHE_DIR $s.base_dir
	ln -s $c.SHARED_DATA_DIR $s.base_dir
	ln -s $c.SHARED_CONFIG_DIR $s.base_dir

	if $open {start $session}
} 


export def delete [session?:string] {
	let _session = get_session $session

	let active = hyprctl clients -j | from json | where initialTitle == $session
	if ($active | is-empty | not $in) {kill -9 ($active.pid | first)}

	let s = get_session_paths $session
	rm -rf $s.base_dir
}

export def start [session?:string] {
	let _session = get_session $session
	let s = get_session_paths $_session

	run-external 'qutebrowser' $'-r=($session)' '--qt-arg' 'qwindowtitle' $'($session)' $'--basedir=($s.base_dir)' $'--config-py=($s.session_config_entry)'
}

