#!/usr/bin/env nu

use /usr/bin/scripts/nushell/nu_path_completer/mod.nu [_main]
use /usr/bin/scripts/nushell/nu_path_completer/preview.nu [main]
use /usr/bin/scripts/nushell/nu_path_completer/filters.nu
use /usr/bin/scripts/nushell/nu_path_completer/input.nu [get_input]
use /usr/bin/scripts/nushell/nui [commandline]

def main [buffer='':string, pos=0:int, state?:record] {
	_main $buffer $pos $state
}

def 'main _filter dir' [] { filters dir }
def 'main _filter hidden' [] { filters hidden }
def 'main _filter ignored' [] { filters ignored }
def 'main _filter absolute' [] { filters absolute }
def 'main _filter start' [start:string] { filters start $start }
def 'main _update input' [] { get_input }
def 'main _preview' [selected:string] { preview $selected }
