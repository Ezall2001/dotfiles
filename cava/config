[general]
framerate = 60
sensitivity = 100
autsens = 1
bars = 0
bar_width = 2
bar_spacing = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

sleep_timer = 0

[input]
method = pipewire
source = auto
sample_rate = 44100
sample_bits = 16
channels = 2
autoconnect = 2


[output]
method = noncurses
orientation = horizontal
channels = mono
mono_option = average
reverse = 0
xaxis = none
synchronized_sync = 0
disable_blanking = 0
show_idle_bar_heads = 1
waveform = 0

[color]
background = default
foreground = blue

gradient = 1
gradient_color_1 = '#ffffff'
gradient_color_2 = '#f33a6a'
gradient_color_3 = '#922340'


[smoothing]
monstercat = 1
waves = 0
noise_reduction = 77


[eq]
1 = 1 # bass
2 = 1
3 = 1 # midtone
4 = 1
5 = 1 # treble
