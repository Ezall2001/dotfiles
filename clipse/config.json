{
	"allowDuplicates": false,
	"maxHistory": 100,
	"deleteAfter": 0,
	"pollInterval": 50,
	"maxEntryLength": 50,
	"enableMouse": false,
	"enableDescription": true,
	"historyFile": "~/.local/state/clipse/clipboard_history.json",
	"logFile": "~/.local/share/clipse/clipse.log",
	"tempDir": "~/.cache/clipse/tmp_files",
	"themeFile": "./theme.json",
	"keyBindings": {
		"up": "k",
		"down": "j",
		"nextPage": "l",
		"prevPage": "h",
		"home": "g",
		"end": "G",
		"clearSelected": "c",
		"selectSingle": "",
		"selectDown": "tab",
		"selectUp": "shift+tab",
		"togglePin": "p",
		"togglePinned": "P",
		"choose": "enter",
		"filter": "/",
		"yankFilter": "ctrl+y",
		"preview": " ",
		"remove": "x",
		"more": "?",
		"quit": "q",
		"forceQuit": "esc"
	},
	"imageDisplay": {
		"type": "kitty",
		"scaleX": 20,
		"scaleY": 20,
		"heightCut": 2
	},
	"autoPaste": {
		"enabled": false,
		"keybind": "ctrl+v",
		"buffer": 10
	},
	"excludedApps": [
		"1Password",
		"Bitwarden",
		"KeePassXC",
		"LastPass",
		"Dashlane",
		"Password Safe",
		"Keychain Access"
	]
}
